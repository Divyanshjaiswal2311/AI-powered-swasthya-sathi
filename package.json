    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.1.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.1.9",
    "react-icons": "^4.12.0",
    "react-toastify": "^11.0.5",
    "axios": "^1.4.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1",
    "bull": "^4.10.4",
    "redis": "^4.6.5",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.32.0",
    "uuid": "^9.0.0"
  }
