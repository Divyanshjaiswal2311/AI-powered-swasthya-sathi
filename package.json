{
  "name": "swasthya-sathi",
  "version": "1.0.0",
  "description": "Swasthya Sathi - Your AI-powered health companion that solves everyday health problems with instant guidance, first aid support, emergency detection & personalized health insights.",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix client",
    "client-install": "cd client && npm install && npm install react-icons@4.12.0 --save",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm run client-install"
  },
